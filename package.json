{
  "name": "simple-nuxt-starter",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "nuxt typecheck",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:nuxt": "vitest run --project nuxt --passWithNoTests",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test": "vitest run --passWithNoTests",
    "check": "pnpm lint:fix && pnpm format:fix && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@iconify-json/material-symbols": "^1.2.51",
    "@nuxt/eslint": "1.12.1",
    "@nuxt/icon": "2.2.0",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.59.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.7.0",
    "jiti": "^2.6.1",
    "nuxt": "^4.2.2",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  }
}
